FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends libgl1 libglib2.0-0 libsm6 libxext6 libxrender-dev libgomp1 ffmpeg && rm -rf /var/lib/apt/lists/*

COPY requirements-agent.txt .
RUN pip install --no-cache-dir -r requirements-agent.txt

COPY agent.py .
COPY yolo11n-pose.pt .

EXPOSE 8000

CMD ["python", "agent.py"]
